{
  "name": "loki",
  "version": "1.0.0",
  "description": "Simple queue worker for Node.js — no Redis required, just your database.",
  "keywords": [
    "queue",
    "worker",
    "job",
    "background",
    "sqlite",
    "postgresql",
    "mysql",
    "async"
  ],
  "license": "MIT",
  "author": "Abdan Zam Zam Ramadhan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdanzamzam/loki.git"
  },
  "bugs": {
    "url": "https://github.com/abdanzamzam/loki/issues"
  },
  "homepage": "https://github.com/abdanzamzam/loki#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "loki": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "better-sqlite3": "^11.8.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0"
  }
}
